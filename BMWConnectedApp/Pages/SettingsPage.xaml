<?xml version="1.0" encoding="utf-8"?>
    <Page
    x:Class="BMWConnectedApp.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BMWConnectedApp">

    
    <ScrollViewer Padding="24">
        <StackPanel Spacing="12">
            <TextBlock Text="Settings" FontSize="24" FontWeight="Bold"/>
            <!-- Simple bindings can reference UserConfig via DataContext set in code-behind -->
            <StackPanel Spacing="6">
                <TextBlock Text="Client ID" FontSize="12" Foreground="Gray"/>
                <TextBox Text="{Binding UserConfig.ClientId, Mode=TwoWay}" Margin="0,0,0,8" MaxWidth="400" Width="400" HorizontalAlignment="Left" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Vehicle VIN" FontSize="12" Foreground="Gray"/>
                <TextBox Text="{Binding UserConfig.VehicleVin, Mode=TwoWay}" Margin="0,0,0,8" MaxWidth="400" Width="400" HorizontalAlignment="Left"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="12">
                <Button x:Name="SaveButton" Content="Save" Click="SaveButton_Click"/>
                <Button x:Name="AuthorizeButton" Content="Authorize" Click="AuthorizeButton_Click" IsEnabled="False"/>
                <TextBlock x:Name="SaveStatus" VerticalAlignment="Center" Foreground="Gray"/>
            </StackPanel>

            <!-- Verification UI is presented in a dialog instead of inline -->
        </StackPanel>
    </ScrollViewer>
</Page>

<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BMWConnectedApp.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BMWConnectedApp"
    xmlns:converters="using:BMWConnectedApp.Converters">

    <Page.Resources>
        <converters:DateFormatConverter x:Key="DateFormatConverter"/>
    </Page.Resources>

    <Grid>
        <TabView CanReorderTabs="True" IsAddTabButtonVisible="False" TabWidthMode="SizeToContent">
            <TabView.TabItems>

                <!-- Account tab -->
                <TabViewItem Header="Account" IsClosable="False">
                    <ScrollViewer Padding="24">
                        <StackPanel Spacing="12" MaxWidth="500" HorizontalAlignment="Left">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Client ID" FontSize="12" Foreground="Gray"/>
                                <TextBox Text="{Binding UserConfig.ClientId, Mode=TwoWay, TargetNullValue='Client ID'}" Width="400" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="12" Margin="0,8,0,0">
                                <Button x:Name="SaveButton" Content="Save"/>
                                <Button x:Name="AuthorizeButton" Content="Authorize" IsEnabled="False"/>
                                <TextBlock x:Name="SaveStatus" VerticalAlignment="Center" Foreground="Gray"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabViewItem>

                <!-- Vehicle tab -->
                <TabViewItem Header="Vehicle" IsClosable="False">
                    <ScrollViewer Padding="24">
                        <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">

                            <!-- VIN field -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="Vehicle VIN" FontSize="12" Foreground="Gray"/>
                                <TextBox Text="{Binding UserConfig.VehicleVin, Mode=TwoWay, TargetNullValue='VIN'}" Width="400" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <!-- Containers section -->
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <TextBlock Text="Containers" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Button x:Name="QueryContainersButton" Content="Query"/>
                                    <ProgressRing x:Name="ContainersLoadingRing" IsActive="False" Width="20" Height="20" Visibility="Collapsed"/>
                                </StackPanel>

                                <!-- Empty state -->
                                <TextBlock x:Name="NoContainersText"
                                           Text="No containers found."
                                           Foreground="Gray"
                                           Visibility="Collapsed"/>

                                <!-- Container list -->
                                <ListView x:Name="ContainersList"
                                          Visibility="Collapsed"
                                          SelectionMode="None"
                                          IsItemClickEnabled="False">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="12,10">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding ContainerName}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding ContainerID}" FontSize="11" Foreground="Gray"/>
                                                        <TextBlock Text="{Binding ContainerPurpose}" FontSize="12" Foreground="Gray"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding State}" FontSize="12" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding Created, Converter={StaticResource DateFormatConverter}}" FontSize="11" Foreground="Gray" HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </TabViewItem>

            </TabView.TabItems>
        </TabView>
    </Grid>
</Page>

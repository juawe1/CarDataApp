<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BMWConnectedApp.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BMWConnectedApp"
    xmlns:conv="using:BMWConnectedApp.Converters"
    xmlns:vm="using:Bmw.Dashboard.Core.ViewModels">
    <Page.Resources>
        <conv:BoolToBrushConverter x:Key="BoolToBrush" />
    </Page.Resources>

    <StackPanel Spacing="24" MaxWidth="1000" Margin="0,120,0,0">

        <!-- Hero Section -->
        <Grid x:Name="HeroGrid" Height="400">
            <Border CornerRadius="12" Background="#1A1A1A">
                <Image x:Name="HeroImage"
                       Opacity="0.7"/>
            </Border>

            <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="20" Padding="16,8" Background="#CC1A1A1A" CornerRadius="12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,8,0" Fill="{x:Bind ViewModel.IsConnected, Mode=OneWay, Converter={StaticResource BoolToBrush}}"/>
                    <TextBlock x:Name="StatusText" Text="{x:Bind ViewModel.ConnectionStatusText, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                </StackPanel>
            </Border>


            <!-- Auth Overlay -->
            <Border x:Name="AuthOverlay" 
            Visibility="{x:Bind ViewModel.IsWaitingForAuth, Mode=OneWay}"
            Background="#EE1A1A1A" CornerRadius="12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                    <TextBlock Text="Link your BMW Account" Foreground="White" Opacity="0.7"/>
                    <TextBlock Text="{x:Bind ViewModel.UserCode, Mode=OneWay}" 
                       FontSize="48" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Static Widgets Row -->
        <Grid ColumnDefinitions="*,*,*">
            <!-- Fuel Widget -->
            <Border Grid.Column="0" Margin="0,0,12,0" Padding="20" Background="#1A1A1A" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Fuel Level" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="85%" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,8"/>
                    <ProgressBar Value="85" Foreground="#2196F3"/>
                </StackPanel>
            </Border>

            <!-- Odometer -->
            <Border Grid.Column="1" Margin="12,0" Padding="20" Background="#1A1A1A" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Odometer" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="12,450 mi" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,8"/>
                    <TextBlock Text="Service in 3,000 mi" Foreground="#4CAF50" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Location -->
            <Border Grid.Column="2" Margin="12,0,0,0" Padding="20" Background="#1A1A1A" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Last Parked" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="Home" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,8"/>
                    <TextBlock Text="Locked &amp; Secured" Foreground="#2196F3" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>

    </StackPanel>
</Page>